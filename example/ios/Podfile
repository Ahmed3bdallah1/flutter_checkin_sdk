platform :ios, '16.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'
ENV['COPYFILE_DISABLE'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # GetID → RecaptchaEnterprise ships static binaries.
  use_frameworks! :linkage => :static

  # Checkin.com GetID iOS SDK (required by flutter_checkin_sdk; not on CocoaPods trunk).
  pod 'GetID', :podspec => 'https://cdn.getid.cloud/sdk/ios/4.1.3/GetID.podspec'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# Allow GetID's static transitive deps under use_frameworks!
pre_install do |installer|
  Pod::Installer::Xcode::TargetValidator.send(
    :define_method,
    :verify_no_static_framework_transitive_dependencies
  ) {}
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      # Avoid CodeSign failures from FinderInfo/quarantine xattrs (iCloud Documents).
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end

  # Downloaded XCFrameworks (GetID, Recaptcha) often carry quarantine/FinderInfo
  pods_root = File.join(__dir__, 'Pods')
  Dir.glob(File.join(pods_root, '**', '*.framework')).each do |framework|
    next unless framework.include?('GetID') || framework.include?('Recaptcha')

    system('xattr', '-cr', framework)
    FileUtils.rm_rf(File.join(framework, '_CodeSignature'))
    system('codesign', '--force', '--sign', '-', '--timestamp=none', framework)
  end
end
